  ComboBox2.Items.Clear;
  ComboBox2.Items.Add('Метод центральних прямокутників');
  ComboBox2.Items.Add('Метод трапецій');
  ComboBox2.Items.Add('Метод Сімпсона');
  ComboBox2.ItemIndex := 0;


  Edit1.Text := '0';
  Edit2.Text := '10';
  Edit3.Text := '5';
  Edit4.Text := '800';

  SpinEdit1.Value := 1;
  SpinEdit2.Value := 1;
  SpinEdit3.Value := 2;
  SpinEdit4.Value := 1;
end;

