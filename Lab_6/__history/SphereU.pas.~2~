unit SphereU;

interface
Uses Sichu,SysUtils;

Type Sphere = class (Sich) // Sphere нащадок класу Sich – кругу
Public
Constructor Create(x, y, z, r: Real);
Function Volume: Real; // Volume – об’єм сфери
// Функції друку і заповнення полів переходять в Sphere без змін
End;

implementation

Constructor Sphere.Create(x, y, z, r: Real);
Begin
Inherited Create(x, y, z ,r);
end;

Function Sphere.Volume: Real; // Volume – об’єм сфери
begin
Result := (4 / 3) * Pi * Rad * Rad * Rad;
end;

end.
