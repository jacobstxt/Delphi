program Project1;

{$APPTYPE CONSOLE}

{$R *.res}

uses
  System.SysUtils,
  SphereU in 'SphereU.pas',
  BallU in 'BallU.pas',
  BankU in 'BankU.pas',
  SavingAccountU in 'SavingAccountU.pas';

Var
  MySphere: Sphere;
  nSphere: Sphere;
  MyBall: Ball;
  nBall: Ball;
  MySavingAccount: SavingAccount;

  newRadius: Real;
  S: String;

begin

newRadius := 20.0;
MySphere:= Sphere.Create;
nSphere := Sphere.Creat(6.0);
MySphere.SetRadius(newRadius);
Writeln (' === Statystyka nSphere ===');
nSphere.DisplayStatistics;

Writeln('N_LKola = ', 2.0 * Pi * MySphere.GetRadius);

MyBall := Ball.Create;
MyBall.SetRadius(newRadius);
WriteLn;
Writeln (' === Statystyka myBall ===');
MyBall.DisplayStatistics;
Writeln (' -------------------- ');


nBall:= Ball.Creat(100, 'Kulka', GREEN);
Writeln (' Ball_Name= ', nBall.GetName);
nBall.SetName ('Sharyk');
Writeln (' Ball_Name = ', nBall.GetName);
S:= nBall.GetColorName;
Writeln (' Ball_Color = ', S);
Writeln (' Ball_LKola = ', 2 * Pi * nBall.GetRadius:1:4);
Writeln (' -------------------- ');

nBall.ResetBall(10,'PingPong',Blue);
Writeln (' Ball_New_Name = ', nBall.GetName);
S:= nBall.GetColorName;
Writeln (' Ball_New_Color = ', S);
Writeln (' Ball_New_Lkola = ', 2 * Pi * nBall.GetRadius:1:4);
Writeln (' -------------------- ');

MySavingAccount := SavingAccount.Initialize('UA127727272277272727','Maksym Baran',1000,5);
MySavingAccount.ShowStatement;
MySavingAccount.Withdraw(500);
MySavingAccount.Deposit(100);



Readln;
end.
