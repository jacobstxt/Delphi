program Project1;

{$APPTYPE CONSOLE}

{$R *.res}

uses
  System.SysUtils,
  AreaU in 'AreaU.pas';

type
  TShape = class
  public
  function Area(a: Integer): Double; overload;        // ътрфЁрҐ
  function Area(a, b: Integer): Double; overload;     // яЁ ьюъґҐэшъ
  function Area(r: Double): Double; overload;         // ъюыю
  end;


function TShape.Area(a: Integer): Double;
begin
  Result := a * a;
end;

function TShape.Area(a, b: Integer): Double;
begin
  Result := a * b;
end;

function TShape.Area(r: Double): Double;
begin
  Result := 3.14 * r * r;
end;


var
  shape: TShape;


begin

shape := TShape.Create;

  Writeln('Square area: ', shape.Area(5):0:2);
  Writeln('Rectangle area: ', shape.Area(4,6):0:2);
  Writeln('Circle area: ', shape.Area(3.5):0:2);

  shape.Free;
  Readln;
end.
