# ==========================================
#   .gitignore для Delphi проектів
# ==========================================

# ----- Скомпільовані файли -----
*.exe
*.dll
*.bpl
*.bpi
*.dcp
*.dcu
*.dcuil
*.dcuos
*.map
*.drc
*.res
*.rsm
*.ocx

# ----- Delphi IDE файли -----
*.~*
*.local
*.identcache
*.projdata
*.tvsconfig
*.dsk
*.vlb

# ----- Backup файли -----
*__history/
__recovery/
*.bak
*.bk
*.orig

# ----- RAD Studio / BDS -----
*.stat
*.dproj.local
*.cbproj.local
*.groupproj.local
*.deployproj
*.entitlements

# ----- Debug / Profiling -----
*.td32
*.map
*.jdbg

# ----- Папки збірки -----
Win32/
Win64/
Android/
Android64/
iOSDevice/
iOSDevice32/
iOSDevice64/
iOSSimulator/
OSX32/
OSX64/
Linux64/

# ----- Output папки -----
Output/
out/
bin/
obj/

# ----- Тимчасові файли IDE -----
*.otares

# ----- ModelMaker Code Explorer -----
*.mcp

# ----- GExperts -----
GExperts.ini

# ----- CnWizards -----
*.cnb

# ----- Відлагодження -----
*.rsm
*.tds

# ----- Документи та архіви -----
*.pdf
*.docx
*.zip