program Project1;

{$APPTYPE CONSOLE}

{$R *.res}

uses
  System.SysUtils,
  PointsU in 'PointsU.pas',
  SichuU in 'SichuU.pas',
  SphereU in 'SphereU.pas';

Var P: Point; // оголошення об’єкта класу Point
  S: Sphere; // оголошення об’єкта класу Sphere

begin

P := Point.Creat(1, 2, 3);
WriteLn(' Coords Point = ',P.GetPoint);
// Конструктором класу Sphere створюємо об’єкт S
S := Sphere.Creat(1, 2, 5, 5);
WriteLn(' Coords Center = ',S.GetPoint);
WriteLn(' Volume Sphere = ',S.Volume:10:4);
ReadLn; // затримання показу результату на екрані
End.
