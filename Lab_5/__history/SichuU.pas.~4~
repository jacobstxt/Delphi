unit SichuU;

interface

Uses PointsU, SysUtils;
Type Sich = class
Private
Center: Point;
Rad: Real;
Public
Constructor Creat (x, y, z, r: Real);
Procedure SetSich (x, y, z, r: Real);
Procedure SetRad (r: Real);
Function GetPoint: String;
Function GetRad: Real;
end;

implementation

Procedure Sich.SetRad(r: Real);
Begin
if r >= 0 then Rad := r
else Rad := 0;
end;
Constructor Sich.Creat (x, y, z, r: Real);
Begin

Center := Point.Creat(x, y, z);
SetRad(r);
end;
Procedure Sich.SetSich(x, y, z, r: Real);
Begin
Center.SetPoint(x, y, z);
SetRad(r);
end;
Function Sich.GetPoint:String;
Begin
Result := Center.GetPoint+ ', Rad = ' +FloatToStr(rad);
end;
Function Sich.GetRad: Real;
Begin
Result := Rad;
end;
end.

end.
