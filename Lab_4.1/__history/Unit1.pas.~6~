unit Unit1;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs;

type
  TForm1 = class(TForm)
    procedure FormPaint(Sender: TObject);
end;
  TRectang = class
  private
    coord: Array [0..3] of Integer;
  public
    Constructor Create(left, top, right, bottom : Integer); Overload;
  published
    Constructor Create(topLeft, bottomRight: TPoint); Overload;

  end;
var
  Form1: TForm1;

implementation

{$R *.dfm}
Constructor TRectang.Create(left, top, right, bottom: Integer);
Begin
// Збереження переданих значень
coord[0] := left;
coord[1] := top;
coord[2] := right;
coord[3] := bottom;
end;

Constructor TRectang.Create(topLeft, bottomRight: TPoint);
Begin
// Збереження переданих значень
coord[0] := topLeft.X;
coord[1] := topLeft.Y;
coord[2] := bottomRight.X;
coord[3] := bottomRight.Y;
end;



procedure TForm1.FormPaint(Sender: TObject);
Var rect1, rect2 : TRectang; // оголошуємо 2 об’єкти нашого класу TRectang
point1, point2: TPoint; // оголошуємо 2 об’єкти стандартного класу TPoint
Begin
point1 := Point(65,75); // створюємо об’єкт стандартного класу TPoint
point2 := Point(95,100); // створюємо об’єкт стандартного класу TPoint
rect1 := TRectang.Create(22, 43, 54, 75); // створюємо об’єкт нашого класу TRectang
rect2 := TRectang.Create(point1, point2); // створюємо об’єкт нашого класу TRectang
With Form1.Canvas do
Begin
Pen.Width := 3; // встановлюємо ширину пера для малювання
Pen.Color := clRed; // встановлюємо колір пера – червоний
Rectangle(rect1.coord[0], rect1.coord[1],
rect1.coord[2], rect1.coord[3]); // малюємо червоний прямокутник
Pen.Width := 4; // встановлюємо ширину пера для малювання
Pen.Color:=clGreen; // встановлюємо колір пера – зелений
Rectangle(rect2.coord[0], rect2.coord[1],
rect2.coord[2], rect2.coord[3]); // малюємо зелений прямокутник
End;

end;


